# Server
NODE_ENV=development
PORT=3001

# Database (PostgreSQL) — puerto 15432 con docker-compose
DATABASE_URL="postgresql://postgres:postgres@localhost:15432/whatsend?schema=public"

# Redis — puerto 16379 con docker-compose
REDIS_URL=redis://localhost:16379

# JWT
JWT_SECRET=change_me_to_at_least_64_random_characters_for_production
JWT_REFRESH_SECRET=another_64_random_chars_different_from_jwt_secret
JWT_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=7d

# Admin inicial (solo se usa en el primer seed)
INITIAL_ADMIN_EMAIL=admin@whatsend.local
INITIAL_ADMIN_PASSWORD=ChangeMe123!

# Frontend (CORS)
FRONTEND_URL=http://localhost:5173
